# Copy this to .env and fill in your values

# Gmail address used to SEND contact form emails
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (Settings → Security → App Passwords)
# Do NOT use your main account password
EMAIL_PASS=your-16-char-app-password

# Email address that RECEIVES the contact form submissions
EMAIL_TO=jacobs.meshachiv@gmail.com

# Server port (default: 3000)
PORT=3000
